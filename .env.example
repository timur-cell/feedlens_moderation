# Frontend (Vite SPA) env. Copy to .env.local and adjust as needed.
# These are the only vars the SPA reads (grep `import.meta.env` in src/).
# Backend env lives elsewhere — see the note at the bottom.

# ─── API ──────────────────────────────────────────────────────
# Base URL the SPA prefixes onto /api requests. Leave empty to use the
# same origin (dev: Vite proxies /api + /image-proxy to localhost:3000).
VITE_API_BASE=

# ─── Preview mode ─────────────────────────────────────────────
# "true" reveals the one-click test-user login (TestUserLoginSection).
VITE_IS_PREVIEW=false

# ─── Test user (only used when VITE_IS_PREVIEW=true) ──────────
VITE_TEST_USER_EMAIL=
VITE_TEST_USER_PASSWORD=

# ─── Backend env ──────────────────────────────────────────────
# The Rails API reads its own env, not this file:
#   rails/.env.example          — local development
#   .env.production.example     — production / docker compose
