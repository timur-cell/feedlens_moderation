# ─── Convex ───────────────────────────────────────────────────
# Get these from your Convex dashboard: https://dashboard.convex.dev
CONVEX_DEPLOYMENT=dev:your-deployment-slug
CONVEX_DEPLOY_KEY=dev:your-deployment-slug|<base64_key>
VITE_CONVEX_URL=https://your-deployment-slug.convex.cloud
VITE_CONVEX_SITE_URL=https://your-deployment-slug.convex.site

# ─── Auth (JWT) ───────────────────────────────────────────────
# RSA private key for JWT token signing (PEM format)
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWKS public key set for token verification
JWKS={"keys": [{"kty": "RSA", "use": "sig", "n": "...", "e": "AQAB"}]}

# ─── Viktor Spaces ────────────────────────────────────────────
VIKTOR_SPACES_API_URL=https://your-api-url
VIKTOR_SPACES_PROJECT_NAME=feedlens
VIKTOR_SPACES_PROJECT_SECRET=your_project_secret
SITE_URL=https://your-site-url

# ─── Preview mode ─────────────────────────────────────────────
VITE_IS_PREVIEW=true

# ─── API Keys (set in Convex env vars, NOT in .env.local) ────
# These are set via: npx convex env set KEY value
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-proj-...
# IMPLIO_API_KEY=...
# Shared secret for the /api/push-flagged endpoint (validated in convex/http.ts).
# LAS_PUSH_API_KEY=...
# Password assigned to admin-created accounts when none is supplied (required).
# DEFAULT_USER_PASSWORD=...

# ─── Scripts / QA (shell env, used by scripts/sync-las-from-bq.py & test_qa.py) ─
# LAS_PUSH_API_KEY=...           # must match the Convex LAS_PUSH_API_KEY above
# FEEDLENS_PUSH_URL=https://your-deployment-slug.convex.site/api/push-flagged
# FEEDLENS_API_BASE=https://your-deployment-slug.convex.site/api
# FEEDLENS_API_KEY=...           # bearer token for the QA suite
