# Copy to .env.production and fill in. Used as:
#   docker compose --env-file .env.production \
#     -f docker-compose.yml -f docker-compose.prod.yml up -d --build

# ── Required ────────────────────────────────────────────────────
# Your hostname (DNS A record must point at this server)
DOMAIN=feedlens.example.com
# Generate with: openssl rand -hex 64
SECRET_KEY_BASE=
# Strong DB password (internal to the compose network, but set one anyway)
DATABASE_PASSWORD=
# First admin login (change the password after first login if you prefer)
ADMIN_EMAIL=admin@feedlens.local
ADMIN_PASSWORD=
# Shared key the LAS feed sends in X-Api-Key to POST /api/push-flagged
LAS_PUSH_API_KEY=

# Keep the app port off the public interface; Caddy serves 80/443
APP_BIND=127.0.0.1

# ── AI (rules engine works without these; AI features need them) ─
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Implio: stub mode logs payloads instead of sending. Flip to
#    false + set the key only when ready for real submissions. ────
IMPLIO_STUB=true
IMPLIO_API_KEY=

# ── Optional ────────────────────────────────────────────────────
# Default password for admin-created users when none supplied
DEFAULT_USER_PASSWORD=
# SMTP for Devise password-reset mail (omit to disable deliveries)
#SMTP_ADDRESS=
#SMTP_PORT=587
#SMTP_USERNAME=
#SMTP_PASSWORD=
# Image registry: mirror.gcr.io (default) or docker.io
#BASE_REGISTRY=docker.io
